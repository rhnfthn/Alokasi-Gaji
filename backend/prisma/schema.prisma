generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum WalletType {
  CASH
  BANK
  EWALLET
  CARD
  OTHER
}

enum TransactionType {
  INCOME
  EXPENSE
  GOAL_CONTRIBUTION
  ADJUSTMENT
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  email     String   @unique
  password  String
  avatar    String?
  role      UserRole @default(USER)

  resetPasswordTokenHash String?
  resetPasswordExpiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  wallets       Wallet[]
  incomes       Income[]
  expenses      Expense[]
  budgets       Budget[]
  goals         Goal[]
  transactions  Transaction[]
  notifications Notification[]
  notificationBroadcasts NotificationBroadcast[]
  settings      Settings?

  // Admin features
  submittedTickets  SupportTicket[] @relation("UserTickets")
  assignedTickets   SupportTicket[] @relation("AssignedTickets")
  ticketReplies     TicketReply[]
  adminLogs         AdminLog[]
  adminReports      AdminReport[]

  @@map("users")
}

model Wallet {
  id       String     @id @default(uuid()) @db.Uuid
  userId   String     @db.Uuid
  name     String
  type     WalletType
  balance  Decimal    @default(0) @db.Decimal(14, 2)
  currency String     @default("IDR")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  incomes      Income[]
  expenses     Expense[]
  transactions Transaction[]

  @@index([userId])
  @@map("wallets")
}

model Income {
  id       String   @id @default(uuid()) @db.Uuid
  userId   String   @db.Uuid
  walletId String   @db.Uuid
  category String
  amount   Decimal  @db.Decimal(14, 2)
  date     DateTime
  note     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  transaction Transaction?

  @@index([userId, date])
  @@index([walletId])
  @@map("income")
}

model Expense {
  id       String   @id @default(uuid()) @db.Uuid
  userId   String   @db.Uuid
  walletId String   @db.Uuid
  title    String   @default("Expense")
  category String
  amount   Decimal  @db.Decimal(14, 2)
  date     DateTime
  note     String?
  receiptUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  transaction Transaction?

  @@index([userId, date])
  @@index([walletId])
  @@map("expenses")
}

model Budget {
  id       String  @id @default(uuid()) @db.Uuid
  userId   String  @db.Uuid
  category String
  amount   Decimal @db.Decimal(14, 2)
  month    Int
  year     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category, month, year])
  @@index([userId, month, year])
  @@map("budgets")
}

model Goal {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  title        String
  targetAmount Decimal  @db.Decimal(14, 2)
  savedAmount  Decimal  @default(0) @db.Decimal(14, 2)
  deadline     DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("goals")
}

model Transaction {
  id        String          @id @default(uuid()) @db.Uuid
  userId    String          @db.Uuid
  walletId  String          @db.Uuid
  type      TransactionType
  category  String?
  amount    Decimal         @db.Decimal(14, 2)
  date      DateTime
  note      String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  incomeId  String? @unique @db.Uuid
  expenseId String? @unique @db.Uuid

  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet  Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  income  Income?  @relation(fields: [incomeId], references: [id], onDelete: SetNull)
  expense Expense? @relation(fields: [expenseId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([walletId, date])
  @@map("transactions")
}

model Notification {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  broadcastId String? @db.Uuid
  title      String
  body       String
  readAt     DateTime?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  broadcast NotificationBroadcast? @relation(fields: [broadcastId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([broadcastId])
  @@map("notifications")
}

model NotificationBroadcast {
  id          String   @id @default(uuid()) @db.Uuid
  createdById String   @db.Uuid
  title       String
  body        String
  type        String   @default("announcement")
  audience    String   @default("ALL")
  status      String   @default("SENT")
  createdAt   DateTime @default(now())

  createdBy     User           @relation(fields: [createdById], references: [id], onDelete: Cascade)
  notifications Notification[]

  @@index([createdAt])
  @@index([createdById, createdAt])
  @@map("notification_broadcasts")
}

model Settings {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @db.Uuid
  defaultCurrency String   @default("IDR")
  darkMode        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("settings")
}

// ==================== ADMIN FEATURES ====================

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ReportType {
  SYSTEM_OVERVIEW
  SUPPORT_OVERVIEW
  FINANCE_OVERVIEW
}

enum ReportStatus {
  DRAFT
  GENERATED
  FAILED
}

model SupportTicket {
  id          String         @id @default(uuid()) @db.Uuid
  userId      String         @db.Uuid
  subject     String
  description String
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  assignedTo  String?        @db.Uuid
  resolvedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user     User            @relation("UserTickets", fields: [userId], references: [id], onDelete: Cascade)
  assignee User?           @relation("AssignedTickets", fields: [assignedTo], references: [id], onDelete: SetNull)
  replies  TicketReply[]

  @@index([userId])
  @@index([status])
  @@map("support_tickets")
}

model TicketReply {
  id        String   @id @default(uuid()) @db.Uuid
  ticketId  String   @db.Uuid
  userId    String   @db.Uuid
  message   String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("ticket_replies")
}

model AdminLog {
  id        String   @id @default(uuid()) @db.Uuid
  adminId   String   @db.Uuid
  action    String
  target    String?
  targetId  String?
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([createdAt])
  @@map("admin_logs")
}

model AdminReport {
  id          String       @id @default(uuid()) @db.Uuid
  createdById String       @db.Uuid
  title       String
  description String?
  type        ReportType
  status      ReportStatus @default(DRAFT)
  dateFrom    DateTime?
  dateTo      DateTime?
  result      Json?
  generatedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  createdBy User @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([createdById])
  @@index([createdAt])
  @@map("admin_reports")
}

model FeatureFlag {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  name        String
  description String?
  enabled     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("feature_flags")
}

model DefaultCategory {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  type      String   // 'income' or 'expense'
  icon      String?
  color     String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, type])
  @@map("default_categories")
}
